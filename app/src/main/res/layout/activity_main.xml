<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- โลโก้แอป -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="App Logo" />

        <!-- หัวข้อเซิร์ฟเวอร์ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="เลือกเซิร์ฟเวอร์"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <!-- Spinner เลือกเซิร์ฟเวอร์ -->
        <Spinner
            android:id="@+id/serverSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background" />

        <!-- การ์ดแสดงข้อมูลเซิร์ฟเวอร์ปัจจุบัน -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgServerFlag"
                    android:layout_width="40dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="12dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="Server Flag" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvServerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thailand Server"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvServerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ออนไลน์: 875 / จำกัด: 1200"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="73%"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:background="@drawable/bg_percentage_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- สถานะการเชื่อมต่อ -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- ปุ่มเชื่อมต่อ (Material Card Button) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnConnectCard"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#2196F3"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/btnConnectText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_connect"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
